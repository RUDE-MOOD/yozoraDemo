     setFocusTarget: (target) => set({ focusTarget: [...target] }),
 
+    // --- Supabase Realtime: 浠栥儑銉愩偆銈广亱銈夈伄鏄熻拷鍔犮倰銉偄銉偪銈ゃ儬鍚屾湡 ---
+    subscribeToStars: () => {
